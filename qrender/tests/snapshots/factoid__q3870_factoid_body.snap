<body>
<div class="page">
  <header class="page-header">
    <h1>Nairobi</h1>
    
    <p class="page-header__description">capital city of Kenya</p>
    
  </header>

  <main class="cards">
    
    <section class="card">
      <h2 class="card__title">Names</h2>
      
      <dl class="kv">
        
        <dt>official name</dt>
        <dd>
          <span class="kv__value">Nairobi</span>
        </dd>
        
        <dt>native label</dt>
        <dd>
          <span class="kv__value">Nairobi</span>
        </dd>
        
        <dt>demonym</dt>
        <dd>
          <span class="kv__value">Nairobien (applies to part: masculine singular)</span><span class="kv__value">Nairobienne (applies to part: feminine singular)</span><span class="kv__value">Nairobian</span><span class="kv__value">nairobienne (applies to part: feminine singular)</span><span class="kv__value">Monairobi</span><span class="kv__value">nairobien (applies to part: masculine singular)</span><span class="kv__value">Najrobiano</span>
        </dd>
        
      </dl>

      
    </section>
    
